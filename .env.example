# Required — Supabase PostgreSQL (database only; no Supabase Storage)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET_HERE

# Payload / Next (optional; used for absolute URLs in emails, previews, etc.)
# NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Postgres pool (optional tuning)
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
# TLS for managed DB on serverless (Supabase/Neon/RDS): auto-detected from host / sslmode=require.
# PG_POOL_SSL=off          # disable explicit pool.ssl
# PG_POOL_SSL=require      # force TLS options on the pool
# PG_SSL_STRICT=true       # set rejectUnauthorized: true (default is looser for pooler certs)

# Vercel: set the same DATABASE_URL / PAYLOAD_SECRET / Cloudinary vars in Project → Settings → Environment Variables.
# Use the DB provider’s pooling URI for serverless (e.g. Supabase “Transaction” pooler), not only the direct DB URL.

# Cloudinary — images (WebP CDN) + PDFs (raw); files are not stored locally
# Option A (recommended): single line from Cloudinary Dashboard → “API Environment variable”
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: three separate variables
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder prefix in Cloudinary
# CLOUDINARY_UPLOAD_FOLDER=horizon-cms

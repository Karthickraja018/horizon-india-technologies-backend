# Required — Supabase PostgreSQL (database only; no Supabase Storage)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET_HERE

# Payload / Next (optional; used for absolute URLs in emails, previews, etc.)
# NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Postgres pool (optional tuning)
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000

# Cloudinary — images (WebP CDN) + PDFs (raw); files are not stored locally
# Option A (recommended): single line from Cloudinary Dashboard → “API Environment variable”
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: three separate variables
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder prefix in Cloudinary
# CLOUDINARY_UPLOAD_FOLDER=horizon-cms
